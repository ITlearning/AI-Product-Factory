# Upstash Redis — Vercel Marketplace 자동 주입 (Production/Preview)
# 로컬 개발 시: `vercel env pull .env.local`
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — Vercel Marketplace에서 1클릭으로 자동 주입
# (대시보드 > Storage/Integrations > Marketplace > Resend > Connect)
RESEND_API_KEY=

# 임시 테스트 메일 토큰 — /api/send-test-email?token=... 검증용
# Vercel 대시보드 > Settings > Environment Variables 에서 수동 추가 (예: abcd1234)
TEST_EMAIL_TOKEN=
